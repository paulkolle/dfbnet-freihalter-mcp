# DFBNet Freihalter MCP Beispiel-Konfiguration
#
# Kopieren nach ~/.dfbnet_env:
#   cp .env.example ~/.dfbnet_env
#   chmod 600 ~/.dfbnet_env
#
# Danach Werte anpassen. Diese Datei hier enthält KEINE echten Secrets.

# Pflicht: deine Schiedsrichter-/Referee-ID aus DFBNet SRIA.
# Du findest sie z.B. in den API-URLs der SRIA-Webapp:
# /api/referee/referee/<DFBNET_REFEREE_ID>/exemption
DFBNET_REFEREE_ID=<deine-referee-id>

# Lokale Token-/Storage-State-Dateien, erzeugt durch scripts/dfbnet_login_probe.py.
# Nutze absolute Pfade, besonders wenn Hermes den MCP startet.
DFBNET_STORAGE_STATE=/absoluter/pfad/zum/dfbnet-freihalter-mcp/dfbnet_probe_out/storage_state.json
DFBNET_TOKEN_STATE=/absoluter/pfad/zum/dfbnet-freihalter-mcp/dfbnet_probe_out/token_state.json

# Standardwerte, normalerweise unverändert lassen.
DFBNET_TIMEZONE=Europe/Berlin
DFBNET_VERIFY_FROM=2025-07-01T00:00:00.000Z
DFBNET_API_BASE_URL=https://api.dfbnet.org/api/referee
DFBNET_AUTH_BASE_URL=https://auth.dfbnet.org/realms/dfbnet
DFBNET_CLIENT_ID=referee-administration
DFBNET_ORIGIN=https://sria.dfbnet.org

# Optional: nur für Headless-Auto-Login im Probe-Script.
# Wenn du dein Passwort nicht lokal speichern willst, lasse diese Werte weg
# und nutze den manuellen Browser-Login.
# DFBNET_LOGIN_ID=<dein-dfbnet-login>
# DFBNET_PASSWORD=<dein-dfbnet-passwort>
